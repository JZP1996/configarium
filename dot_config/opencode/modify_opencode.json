#!/bin/sh
# chezmoi modify_ script for ~/.config/opencode/opencode.json.
set -eu

input="$(cat)"
[ -z "$input" ] && input='{}'

if ! command -v node >/dev/null 2>&1; then
  printf '%s\n' 'warning: node is unavailable; OpenCode managed permissions were not applied' >&2
  printf '%s' "$input"
  exit 0
fi

printf '%s' "$input" | node -e '
  const fs = require("fs")
  const existing = JSON.parse(fs.readFileSync(0, "utf8") || "{}")
  const permission = existing.permission && typeof existing.permission === "object"
    && !Array.isArray(existing.permission) ? existing.permission : {}

  const mergeRules = (current, managed) =>
    current && typeof current === "object" && !Array.isArray(current)
      ? { ...current, ...managed }
      : typeof current === "string"
        ? { "*": current, ...managed }
        : managed

  const managedPermission = {
    "*": "ask",
    read: "allow",
    glob: "allow",
    grep: "allow",
    list: "allow",
    lsp: "allow",
    webfetch: "allow",
    websearch: "allow",
    question: "allow",
    task: "allow",
    skill: "allow",
    doom_loop: "ask"
  }
  const managedExternal = {
    "~/.config/opencode/**": "allow"
  }
  const managedEdit = {
    "~/.config/opencode/**": "deny"
  }

  existing.permission = {
    ...permission,
    ...managedPermission,
    external_directory: mergeRules(permission.external_directory, managedExternal),
    edit: mergeRules(permission.edit, managedEdit)
  }

  process.stdout.write(`${JSON.stringify(existing, null, 2)}\n`)
'