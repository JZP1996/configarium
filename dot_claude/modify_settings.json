#!/bin/sh
# chezmoi modify_ script for ~/.claude/settings.json.
set -eu

input="$(cat)"
[ -z "$input" ] && input='{}'

if ! command -v node >/dev/null 2>&1; then
  printf '%s\n' 'warning: node is unavailable; Claude Code managed settings were not applied' >&2
  printf '%s' "$input"
  exit 0
fi

printf '%s' "$input" | node -e '
  const fs = require("fs")
  const config = JSON.parse(fs.readFileSync(0, "utf8") || "{}")
  const claudeAllow = [
    "WebFetch",
    "WebSearch"
  ]
  const fileViewAllow = [
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(less:*)",
    "Bash(more:*)",
    "Bash(file:*)",
    "Bash(stat:*)",
    "Bash(wc:*)",
    "Bash(column:*)",
    "Bash(sort:*)",
    "Bash(uniq:*)",
    "Bash(date:*)",
    "Bash(echo:*)",
    "Bash(pwd:*)",
    "Bash(which:*)"
  ]
  const searchAllow = [
    "Bash(ls:*)",
    "Bash(tree:*)",
    "Bash(find:*)",
    "Bash(rg:*)",
    "Bash(grep:*)",
    "Bash(diff:*)"
  ]
  const gitReadAllow = [
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git show:*)",
    "Bash(git blame:*)",
    "Bash(git describe:*)",
    "Bash(git rev-parse:*)",
    "Bash(git ls-files:*)",
    "Bash(git branch --list:*)",
    "Bash(git branch -r --list:*)"
  ]
  const gitWriteAllow = [
    "Bash(git add:*)",
    "Bash(git restore:*)",
    "Bash(git switch:*)",
    "Bash(git checkout:*)",
    "Bash(git commit:*)",
    "Bash(git stash:*)",
    "Bash(git stash list:*)"
  ]
  const developmentAllow = [
    "Bash(dotnet:*)",
    "Bash(msbuild:*)",
    "Bash(nuget:*)",
    "Bash(python:*)",
    "Bash(python3:*)",
    "Bash(pytest:*)",
    "Bash(pip:*)",
    "Bash(pip3:*)",
    "Bash(node:*)",
    "Bash(npm:*)",
    "Bash(npx:*)",
    "Bash(pnpm:*)",
    "Bash(yarn:*)",
    "Bash(cargo:*)",
    "Bash(go:*)",
    "Bash(mvn:*)",
    "Bash(gradle:*)",
    "Bash(make:*)",
    "Bash(cmake:*)"
  ]
  const dockerReadAllow = [
    "Bash(docker ps:*)",
    "Bash(docker images:*)",
    "Bash(docker logs:*)",
    "Bash(docker inspect:*)",
    "Bash(docker compose ps:*)",
    "Bash(docker compose logs:*)",
    "Bash(docker compose config:*)"
  ]
  const chezmoiAllow = [
    "Bash(chezmoi diff:*)",
    "Bash(chezmoi data:*)",
    "Bash(chezmoi managed:*)",
    "Bash(chezmoi execute-template:*)",
    "Bash(chezmoi cat:*)",
    "Bash(chezmoi source-path:*)",
    "Bash(chezmoi status:*)",
    "Bash(chezmoi verify:*)"
  ]
  const managedAllow = [
    ...claudeAllow,
    ...fileViewAllow,
    ...searchAllow,
    ...gitReadAllow,
    ...gitWriteAllow,
    ...developmentAllow,
    ...dockerReadAllow,
    ...chezmoiAllow
  ]
  const managedEnv = {
    CLAUDE_CODE_ATTRIBUTION_HEADER: "0",
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC: "1",
    CLAUDE_CODE_AUTO_COMPACT_WINDOW: "1000000",
    CLAUDE_AUTOCOMPACT_PCT_OVERRIDE: "85"
  }
  const permissions = config.permissions && typeof config.permissions === "object"
    && !Array.isArray(config.permissions) ? config.permissions : {}
  const env = config.env && typeof config.env === "object" && !Array.isArray(config.env)
    ? config.env : {}
  const allow = Array.isArray(permissions.allow) ? permissions.allow : []

  config.permissions = { ...permissions, allow: [...new Set([...allow, ...managedAllow])] }
  config.autoCompactEnabled = false
  config.disableDeepLinkRegistration = "disable"
  config.env = {
    ...env,
    ...managedEnv
  }

  process.stdout.write(`${JSON.stringify(config, null, 2)}\n`)
'
