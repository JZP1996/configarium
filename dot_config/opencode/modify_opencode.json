#!/bin/sh
# chezmoi modify_ script for ~/.config/opencode/opencode.json.
set -eu

input="$(cat)"
[ -z "$input" ] && input='{}'

if ! command -v node >/dev/null 2>&1; then
  printf '%s\n' 'warning: node is unavailable; OpenCode managed permissions were not applied' >&2
  printf '%s' "$input"
  exit 0
fi

printf '%s' "$input" | node -e '
  const fs = require("fs")
  const config = JSON.parse(fs.readFileSync(0, "utf8") || "{}")
  const permission = config.permission && typeof config.permission === "object"
    && !Array.isArray(config.permission) ? config.permission : {}

  const mergeRules = (current, managed) =>
    current && typeof current === "object" && !Array.isArray(current)
      ? { ...current, ...managed }
      : typeof current === "string"
        ? { "*": current, ...managed }
        : managed

  const managedPermission = {
    "*": "ask",
    read: "allow",
    glob: "allow",
    grep: "allow",
    list: "allow",
    lsp: "allow",
    webfetch: "allow",
    websearch: "allow",
    question: "allow",
    task: "allow",
    skill: "allow",
    doom_loop: "ask"
  }
  const managedExternal = {
    "~/.config/opencode/**": "allow"
  }
  const managedEdit = {
    "~/.config/opencode/**": "deny"
  }
  const managedBash = Object.fromEntries([
    "*",
    "pwd*",
    "ls*",
    "tree*",
    "find*",
    "stat*",
    "file*",
    "which*",
    "cat*",
    "head*",
    "tail*",
    "wc*",
    "sort*",
    "uniq*",
    "column*",
    "diff*",
    "grep*",
    "rg*",
    "date*",
    "echo*",
    "git status*",
    "git diff*",
    "git log*",
    "git show*",
    "git blame*",
    "git describe*",
    "git rev-parse*",
    "git ls-files*",
    "chezmoi diff*",
    "chezmoi data*",
    "chezmoi managed*",
    "chezmoi execute-template*",
    "chezmoi cat*",
    "chezmoi source-path*",
    "chezmoi status*",
    "chezmoi verify*"
  ].map((pattern) => [pattern, pattern === "*" ? "ask" : "allow"]))

  config.permission = {
    ...permission,
    ...managedPermission,
    external_directory: mergeRules(permission.external_directory, managedExternal),
    edit: mergeRules(permission.edit, managedEdit),
    bash: mergeRules(permission.bash, managedBash)
  }

  process.stdout.write(`${JSON.stringify(config, null, 2)}\n`)
'