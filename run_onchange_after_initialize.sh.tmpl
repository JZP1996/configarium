{{ $isWSL := and (eq .chezmoi.os "linux") (ne (env "WSL_DISTRO_NAME") "") -}}
{{ if or (eq .chezmoi.os "darwin") $isWSL -}}
#!/bin/sh
# Per-machine zsh initialization for macOS and WSL.
# Opt-in value: {{ env "CHEZMOI_INSTALL_OPTIONAL_TOOLS" | quote }}
set -eu

# Always ensure ~/.zshrc loads the common chezmoi-managed configuration.
ZSHRC="$HOME/.zshrc"
SRC_LINE='[[ -f ~/.zsh/.zshrc.common ]] && source ~/.zsh/.zshrc.common'

[ -f "$ZSHRC" ] || touch "$ZSHRC"

if ! grep -qFx "$SRC_LINE" "$ZSHRC"; then
  printf '%s\n\n%s\n' "$SRC_LINE" "$(cat "$ZSHRC")" > "$ZSHRC"
fi

if [ "${CHEZMOI_INSTALL_OPTIONAL_TOOLS:-}" != "1" ]; then
  exit 0
fi

# Revisions are intentionally fixed; see THIRD_PARTY_NOTICES.md before updating.
install_git_revision() {
  repository="$1"
  revision="$2"
  destination="$3"

  if [ -d "$destination/.git" ]; then
    current_repository=$(git -C "$destination" remote get-url origin 2>/dev/null || true)
    if [ "$current_repository" != "$repository" ]; then
      printf 'error: %s uses origin %s; expected %s\n' \
        "$destination" "${current_repository:-unknown}" "$repository" >&2
      exit 1
    fi

    if [ -n "$(git -C "$destination" status --porcelain)" ]; then
      printf 'error: %s has local changes; refusing to change its revision\n' "$destination" >&2
      exit 1
    fi

    current_revision=$(git -C "$destination" rev-parse HEAD 2>/dev/null || true)
    if [ "$current_revision" = "$revision" ]; then
      return
    fi

    git -C "$destination" fetch --depth 1 origin "$revision"
    git -C "$destination" checkout --detach "$revision"
    return
  fi

  if [ -e "$destination" ]; then
    printf 'error: %s exists but is not a git checkout\n' "$destination" >&2
    exit 1
  fi

  git clone "$repository" "$destination"
  git -C "$destination" checkout --detach "$revision"
}

# Install Oh My Zsh without executing a remote installer script.
install_git_revision \
  https://github.com/ohmyzsh/ohmyzsh.git \
  677a4592b18c08ddea737f8aca70bac0e9fc9313 \
  "$HOME/.oh-my-zsh"

# Install zsh plugins into ~/.zsh (paths match ~/.zsh/.zshrc.common).
ZSH_DIR="$HOME/.zsh"
mkdir -p "$ZSH_DIR"
install_git_revision \
  https://github.com/zsh-users/zsh-autosuggestions.git \
  85919cd1ffa7d2d5412f6d3fe437ebdbeeec4fc5 \
  "$ZSH_DIR/zsh-autosuggestions"
install_git_revision \
  https://github.com/zsh-users/zsh-syntax-highlighting.git \
  1d85c692615a25fe2293bdd44b34c217d5d2bf04 \
  "$ZSH_DIR/zsh-syntax-highlighting"
{{ end -}}
