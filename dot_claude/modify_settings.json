#!/bin/sh
# chezmoi modify_ script for ~/.claude/settings.json.
# Runs on every `chezmoi apply` with the current file content on stdin; stdout
# becomes the new content.
set -eu

input="$(cat)"
[ -z "$input" ] && input='{}'

if ! command -v node >/dev/null 2>&1; then
  printf '%s' "$input"
  exit 0
fi

printf '%s' "$input" | node -e '
  const fs = require("fs")
  const config = JSON.parse(fs.readFileSync(0, "utf8") || "{}")
  const managed = [
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(grep:*)",
    "Bash(rg:*)",
    "Bash(find:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(diff:*)",
    "Bash(tree:*)",
    "Bash(pwd:*)",
    "Bash(which:*)",
    "Bash(file:*)",
    "Bash(stat:*)",
    "Bash(date:*)",
    "Bash(echo:*)",
    "Bash(sort:*)",
    "Bash(uniq:*)",
    "Bash(column:*)",
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git show:*)",
    "Bash(git blame:*)",
    "Bash(git ls-files:*)",
    "Bash(git rev-parse:*)",
    "Bash(git describe:*)",
    "Bash(chezmoi diff:*)",
    "Bash(chezmoi data:*)",
    "Bash(chezmoi managed:*)",
    "Bash(chezmoi execute-template:*)",
    "Bash(chezmoi cat:*)",
    "Bash(chezmoi source-path:*)",
    "Bash(chezmoi status:*)",
    "Bash(chezmoi verify:*)",
    "WebSearch",
    "WebFetch"
  ]
  const permissions = config.permissions && typeof config.permissions === "object"
    && !Array.isArray(config.permissions) ? config.permissions : {}
  const env = config.env && typeof config.env === "object" && !Array.isArray(config.env)
    ? config.env : {}
  const allow = Array.isArray(permissions.allow) ? permissions.allow : []

  config.permissions = { ...permissions, allow: [...new Set([...allow, ...managed])] }
  config.autoCompactEnabled = false
  config.disableDeepLinkRegistration = "disable"
  config.env = {
    ...env,
    CLAUDE_CODE_ATTRIBUTION_HEADER: "0",
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC: "1",
    CLAUDE_CODE_AUTO_COMPACT_WINDOW: "1000000",
    CLAUDE_AUTOCOMPACT_PCT_OVERRIDE: "85"
  }

  process.stdout.write(`${JSON.stringify(config, null, 2)}\n`)
'
